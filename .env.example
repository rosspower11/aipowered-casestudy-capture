# Notion ----------------------------------------------------------------------
# Create an integration at https://www.notion.so/profile/integrations
# Then share the Case Studies database with that integration.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Database ID (from the URL of the Case Studies database)
NOTION_DATABASE_ID=357b938b5c83803aa926cabe1ba7804a

# Cloudflare R2 ---------------------------------------------------------------
# In Cloudflare > R2 > Manage API tokens, create an "Object Read & Write" token.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=ai-powered-case-studies
# Public domain you've connected to the bucket (R2 > Bucket > Settings > Custom Domains)
# Used to make uploaded files visible from Notion.
R2_PUBLIC_BASE_URL=https://files.aipowered.xyz
